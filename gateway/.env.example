# "production" gates production-only hardening: hard-fails startup on a
# missing/placeholder GATEWAY_SHARED_SECRET instead of just warning, and
# switches request logging to the more detailed "combined" format. Leave
# unset for local development.
NODE_ENV=

# Port the gateway's MCP endpoint listens on
PORT=4200

# Where the gateway's SQLite db lives (shared schema with admin-portal/api --
# MUST point both services at the exact same file). Defaults to a repo-root
# "data/" folder, which already works out of the box; only override this
# with an absolute path if you move either service elsewhere.
DB_PATH=../data/gateway.sqlite

# Shared secret the agent builder platform must send as the X-Gateway-Auth
# header on every request. Requests without a matching secret are rejected
# outright, before any identity/permission logic runs.
GATEWAY_SHARED_SECRET=change-me

# "shadow" logs allow/deny decisions without blocking anything -- use this to
# validate tool tagging against real traffic before cutting over. "enforce"
# actually blocks denied tools/calls and hides them from tools/list.
# REQUIRED when NODE_ENV=production: the gateway refuses to start unless this
# is explicitly one of the two values (shadow is fail-open, so production
# must never fall into it by accident/typo).
GATEWAY_ENFORCE_MODE=shadow

# --- Upstream real MCP server connection (see core/src/mcp/upstreamConfig.ts) ---
# Swap UPSTREAM_MCP_SERVER_URL to point at the org's real MCP server instead
# of the bundled mock -- no code change needed.
MCP_TRANSPORT=http
UPSTREAM_MCP_SERVER_URL=http://localhost:4000/mcp
MCP_STDIO_COMMAND=
MCP_STDIO_ARGS=
MCP_BEARER_TOKEN=
MCP_AUTH_HEADER_NAME=
MCP_AUTH_HEADER_VALUE=
MCP_EXTRA_HEADERS=

# Rate limit on POST /mcp -- bounds abuse/runaway traffic. Defaults shown
# are generous enough for normal agent-builder traffic and for this repo's
# own e2e test suite; tighten if needed.
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_RATE_LIMIT_MAX=300

# Days of allow/deny decision history kept in gateway_access_log before the
# daily sweep deletes older rows (tools/list writes one row per tool per
# request, so this table grows fast at scale).
ACCESS_LOG_RETENTION_DAYS=90
