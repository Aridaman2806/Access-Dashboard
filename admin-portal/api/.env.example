# "production" gates production-only hardening: hard-fails startup if
# SESSION_SECRET/ADMIN_PASSWORD are still placeholders or ADMIN_FRONTEND_ORIGIN
# is unset, marks the session cookie "secure" (HTTPS-only), and tightens CORS
# to only ADMIN_FRONTEND_ORIGIN. Leave unset for local development.
NODE_ENV=

# Port the admin portal's REST API listens on
PORT=4300

# IMPORTANT: this MUST be the SAME sqlite file as gateway/'s DB_PATH -- grants/
# tags made here only take effect at enforcement time if the gateway reads
# from this same database. The default below already resolves to a shared
# repo-root "data/" folder, matching the gateway's default.
DB_PATH=../../data/gateway.sqlite

# Session cookie signing secret and a single hardcoded admin login for MVP.
# Flagged in the plan as needing real hardening (SSO, multi-admin, etc.)
# before production use -- this is a sensitive permission-management surface.
SESSION_SECRET=change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Comma-separated origin(s) allowed to make credentialed requests to this API
# -- i.e. the admin-frontend's real URL(s). Required in production; local
# dev falls back to a permissive default if left unset.
ADMIN_FRONTEND_ORIGIN=http://localhost:5173

# Rate limit on POST /auth/login -- brute-force protection on the admin
# password.
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_LOGIN_RATE_LIMIT_MAX=20

# --- Upstream real MCP server connection (same vars as gateway/.env.example) ---
MCP_TRANSPORT=http
UPSTREAM_MCP_SERVER_URL=http://localhost:4000/mcp
MCP_STDIO_COMMAND=
MCP_STDIO_ARGS=
MCP_BEARER_TOKEN=
MCP_AUTH_HEADER_NAME=
MCP_AUTH_HEADER_VALUE=
MCP_EXTRA_HEADERS=
