# Port the admin portal's REST API listens on
PORT=4300

# IMPORTANT: point this at the SAME sqlite file as packages/gateway's DB_PATH
# in any real deployment -- grants/tags made here only take effect at
# enforcement time if the gateway reads from this same database.
DB_PATH=./data/gateway.sqlite

# Session cookie signing secret and a single hardcoded admin login for MVP.
# Flagged in the plan as needing real hardening (SSO, multi-admin, etc.)
# before production use -- this is a sensitive permission-management surface.
SESSION_SECRET=change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Upstream real MCP server connection (same vars as packages/gateway/.env.example) ---
MCP_TRANSPORT=http
UPSTREAM_MCP_SERVER_URL=http://localhost:4000/mcp
MCP_STDIO_COMMAND=
MCP_STDIO_ARGS=
MCP_BEARER_TOKEN=
MCP_AUTH_HEADER_NAME=
MCP_AUTH_HEADER_VALUE=
MCP_EXTRA_HEADERS=
