# Port this backend listens on
PORT=4400

# Session cookie signing secret (dev-only demo, not real security)
SESSION_SECRET=change-me

# The GATEWAY's MCP endpoint -- NOT the real/mock MCP server directly. This
# app must always go through the gateway so enforcement actually applies.
GATEWAY_URL=http://localhost:4200/mcp

# Must match the gateway's own GATEWAY_SHARED_SECRET (gateway/.env)
GATEWAY_SHARED_SECRET=change-me

# Note: intentionally no DB_PATH and no UPSTREAM_MCP_SERVER_URL here -- this
# app has no database and never talks to an MCP server directly, only to
# the gateway above. Swapping the real MCP server in/out is entirely the
# gateway's concern (see gateway/.env.example).
